@namespace Blog.Component

<MMarkdownIt Breaks="true" Typographer="true" Source="@Source" Style="@(Style )" Class="@(Class + " mt-4 pa-1")"/>

@code
{
    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string Style { get; set; }

    [Parameter]
    public string Source { get; set; }

    [Parameter]
    public EventCallback<string> SourceChanged { get; set; }
}

<style>
    pre{
        background-color: aliceblue;
        border-radius: 10px;
    }
    pre code{
        background-color: rgb(0 0 0 / 0%) !important;
    }
    p img{
        width: 100%;
        max-height: 350px;
    }
    table{
      border-collapse: collapse;
      margin: 0 auto;
      text-align: center;
    }
    table td, table th{
      border: 1px solid #cad9ea;
      color: #666;
      height: 30px;
    }
    table thead th{
      background-color: #CCE8EB;
      width: 100px;
    }
    
</style>