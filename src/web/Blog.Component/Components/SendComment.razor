@namespace Blog.Component
@inject IArticleCommentService ArticleCommentService
@inject IPopupService PopupService
@inject IKeyLoadEventBus KeyLoadEventBus

<MTabs
    @bind-Value="tab">
       <MTab>编辑</MTab>
       <MTab>预览</MTab>
</MTabs>

<MTabsItems Value="tab">
    <MTabItem >
        <MTextarea @bind-Value="@Comment" >
        </MTextarea>
    </MTabItem>
    <MTabItem Style="min-height: 180px">
        <Markdown @bind-Source="@Comment"></Markdown>
    </MTabItem>
</MTabsItems>

<MButton Block OnClick="Send">提交</MButton>