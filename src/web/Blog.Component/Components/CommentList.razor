@namespace Blog.Component
@inject IArticleCommentService ArticleCommentService
@inject IKeyLoadEventBus KeyLoadEventBus

<MList ThreeLine>
    @foreach (var item in Comments)
    {
        <MListItem>
            <MListItemAvatar>
                <MImage Src="@item.InfoDto.Avatar"></MImage>
            </MListItemAvatar>
            <MListItemContent>
                <MListItemTitle>@((MarkupString)item.InfoDto.Name)</MListItemTitle>
                <MListItemSubtitle Style="min-height: 50px">
                    <Markdown Style="max-height: 400px;overflow: auto;" @bind-Source="item.Content"></Markdown>
                </MListItemSubtitle>
            </MListItemContent>
        </MListItem>
    }
</MList>
