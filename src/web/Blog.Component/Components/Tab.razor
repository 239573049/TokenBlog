@inject ITagService TagService
@inject IKeyLoadEventBus KeyLoadEventBus
@namespace Blog.Component

<CascadingValue Value="TagId" Name="@nameof(TagId)">
    <MTabs BackgroundColor="indigo" CenterActive Dark>
        @if (_tagDtos != null)
        {
            foreach (var tag in _tagDtos.OrderBy(x => x.Rank))
            {
                <MTab  OnClick="() => SwitchTag(tag.Id)" Style="color: black">@tag.Title</MTab>
            }
        }
    </MTabs>

    <ArticleList/>
</CascadingValue>
